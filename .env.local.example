# Environment Variables untuk Upshare
# Salin file ini menjadi .env.local dan isi nilainya

# ── App ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=link

# ── Supabase ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Mayar.id (Payment Gateway) ───────────────────────
MAYAR_API_KEY=your-mayar-api-key
MAYAR_WEBHOOK_SECRET=your-mayar-webhook-secret
NEXT_PUBLIC_MAYAR_API_URL=https://api.mayar.id/hl/v1

# ── Resend (Email) ────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@upshare.id

# ── Auth ──────────────────────────────────────────────
# Untuk Google OAuth, konfigurasi di Supabase Dashboard
# Auth > Providers > Google
