# ==========================================
# KONFIGURASI APLIKASI
# ==========================================
# URL utama aplikasi, misalnya "http://localhost:3000" atau "https://upshare.id"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Root domain untuk subdomain, misalnya "upshare.id" (biarkan kosong/localhost jika lokal)
NEXT_PUBLIC_ROOT_DOMAIN="upshare.id"


# ==========================================
# SUPABASE (DATABASE & AUTH)
# ==========================================
# URL project Supabase Anda
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-ID].supabase.co"

# Anon key (untuk akses public dari client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Service role key (RAHASIA - hanya untuk server-side/admin bypass RLS)
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"


# ==========================================
# MAYAR (PAYMENT GATEWAY)
# ==========================================
# Base URL API Mayar (Default: https://api.mayar.id/hl/v1)
NEXT_PUBLIC_MAYAR_API_URL="https://api.mayar.id/hl/v1"

# API Key Mayar Anda (dari dashboard developer)
MAYAR_API_KEY="your-mayar-api-key"

# Webhook Secret Mayar untuk verifikasi notifikasi pembayaran
MAYAR_WEBHOOK_SECRET="your-mayar-webhook-secret"


# ==========================================
# UPSTASH REDIS (UNTUK RATE LIMITING)
# ==========================================
# (Opsional) Jika Anda mengaktifkan limit request
UPSTASH_REDIS_REST_URL="https://[YOUR-REGION].upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"


# ==========================================
# RESEND (EMAIL SENDER)
# ==========================================
# API Key untuk kirim email
RESEND_API_KEY="re_your_resend_api_key"

# Alamat email pengirim (cth: noreply@upshare.id)
RESEND_FROM_EMAIL="noreply@upshare.id"
