# ──────────────────────────────────────────────
# Upshare — .gitignore
# ──────────────────────────────────────────────

# ── Dependencies ───────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ────────────────────────────────────
/.next/
/out/
/build

# ── Environment Variables ───────────────────────
# JANGAN pernah commit file .env yang berisi secret!
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
# File example boleh di-commit (tidak ada secret nyata)
.env.local.example
.env.example

# ── Supabase ───────────────────────────────────
.supabase/

# ── Testing ────────────────────────────────────
/coverage
*.lcov
.nyc_output

# ── Debug Logs ─────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS Files ───────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor / IDE ───────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
.history/

# ── TypeScript ─────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ─────────────────────────────────────
.vercel

# ── Misc / Temp ────────────────────────────────
*.pem
*.key
*.cert
.cache
tmp/
temp/
.temp/
